FROM debian:trixie-slim

# Set environment variables to prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# >>>>> 安装系统依赖
RUN apt-get update -qq && apt-get install -qq -y --no-install-recommends \
    # 基础工具
    ca-certificates wget curl locales \
    # 在执行大量小文件写入的操作（如安装成百上千个 deb/rpm 包、运行自动化测试、编译大型项目）时，性能提升非常显著，有时能快好几倍。
    eatmydata \
    # 开发工具
    git procps sudo fzf zsh man-db xz-utils openssh-client \
    # 网络工具
    netcat-openbsd iproute2 net-tools bind9-dnsutils && \
    # 清理缓存
    apt-get clean && rm -rf /var/lib/apt/lists/*

# >>>>> 创建用户和配置 sudo
# https://code.visualstudio.com/remote/advancedcontainers/add-nonroot-user#_creating_a_nonroot_user
RUN groupadd --gid 1000 usr_vscode \
    && useradd --uid 1000 --gid usr_vscode --shell /bin/zsh --create-home usr_vscode \
    && echo "usr_vscode ALL=(root) NOPASSWD: ALL" > /etc/sudoers.d/usr_vscode_user_config \
    && chmod 0440 /etc/sudoers.d/usr_vscode_user_config \
    && cat /etc/passwd
ENV HOME=/home/usr_vscode

# >>>>> 切换到非 root 用户
USER usr_vscode
RUN sudo mkdir /vscode && sudo chown usr_vscode:usr_vscode /vscode

# >>>>> zsh-in-docker 安装和配置
# 要重新触发 zsh 新用户配置向导: autoload -Uz zsh-newuser-install; zsh-newuser-install -f
COPY _build-context/zsh-in-docker-v1.2.1.sh /tmp/zsh-in-docker.sh
RUN set -eux; \
    sh /tmp/zsh-in-docker.sh \
    # # Default powerline10k theme
    -t random \
    -p git \
    -p fzf \
    -a "source ~/.oh-my-zsh/lib/key-bindings.zsh" \
    -a "source ~/.oh-my-zsh/lib/completion.zsh" && \
    # -a "export PROMPT_COMMAND='history -a' && export HISTFILE=/commandhistory/.histfile" \
    sed -i "/export LANG='en_US.UTF-8'/d;/export LANGUAGE='en_US:en'/d;/export LC_ALL='en_US.UTF-8'/d" $HOME/.zshrc

# >>>>>>>>>>>>>>>>>>>> zsh 配置
# /etc/zsh/zshenv 对所有 zsh 实例生效（交互式 + 非交互式）
RUN echo 'builtin source /etc/zsh/devcontainer-init.zsh' | sudo tee -a /etc/zsh/zshenv > /dev/null

RUN cat <<'EOF' >> /home/usr_vscode/.zshrc

# >>>>> VS Code Shell Integration
[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"
# <<<<< VS Code Shell Integration

# >>>>> 自定义别名
alias clean-node-modules='setopt rm_star_silent; rm -rf node_modules/.*; rm -rf node_modules/*; unsetopt rm_star_silent'
# <<<<< 自定义别名
EOF
# <<<<<<<<<<<<<<<<<<<< zsh 配置

ENV BUN_INSTALL_CACHE_DIR="/vscode/bun/install-cache"
ENV BUN_INSTALL_BIN="${HOME}/.bun/bin"

# ENV XDG_CACHE_HOME="/vscode/xdg-cache"
# ENV XDG_CONFIG_HOME="/vscode/xdg-config"
ENV XDG_DATA_HOME="/vscode/xdg-data" \
    XDG_STATE_HOME="/vscode/xdg-state"

ENV PNPM_HOME="${HOME}/.pnpm"

ENV INSTALL_NOVNC=false \
    VNC_RESOLUTION="1680x1050x16" \
    NODE_OPTIONS="--max-old-space-size=4096" \
    TZ="Asia/Shanghai"

RUN mkdir -p /vscode/claude-config
ENV DEVCONTAINER=true \
    DISABLE_TELEMETRY=1 \
    IS_SANDBOX=true

ENV CODEX_HOME=/vscode/codex-home

# bash 非交互式 shell 也加载 command_not_found_handle
ENV BASH_ENV=/devcontainer/bash-env.sh

ENV DISPLAY=:1

# Set the default editor and visual
ENV EDITOR="code --wait"
ENV VISUAL="code --wait"
# https://github.com/devcontainers/features/blob/b0188f0a5ef98f1c3217b6c0fe14c3ee472fad68/src/common-utils/scripts/rc_snippet.sh#L22
ENV GIT_EDITOR="code --wait"

# >>>>> 复制内置脚本
COPY _build-context/rootfs /
ENV PATH="${BUN_INSTALL_BIN}:${PATH}"
ENV PATH="${PNPM_HOME}:${PATH}"
ENV PATH="/usr/local/bin-mcp-stdio:${PATH}"
# 优先级脚本，确保在 PATH 最前面
ENV PATH="/usr/local/bin-priority:${PATH}"
# 让普通用户也可以编辑 bin-priority 中的脚本
RUN sudo chmod a+w /usr/local/bin-priority /usr/local/bin-priority/*

# 配置 sudo 的 secure_path，确保 sudo 能找到 bin-priority 中的脚本
# 验证: sudo -l | grep -q 'bin-priority'
# 验证: echo $PATH && sudo env | grep PATH
RUN sudo chmod 0440 /etc/sudoers.d/secure_path_config

# 设置入口点为 /bin/sh
ENTRYPOINT ["/bin/sh"]

# 设置默认执行的命令
# 注意：这里使用了 -c 来执行字符串脚本，"-" 是为了给 $@ 占位
CMD ["-c", "echo Container started\ntrap \"exit 0\" 15\n\nexec \"$@\"\nwhile sleep 1 & wait $!; do :; done", "-"]