#!/usr/bin/env bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

# Usage: _apt-install-cached package1 [package2...]
# Example: _apt-install-cached chromium chromium-l10n ffmpeg

if false; then
#-------------------------------------------------------------------------------------------------------------
# 一些资料：
# 查看该软件包安装的所有文件
dpkg -L tigervnc-standalone-server | grep bin

# 你的 `vim` 命令在系统里是这样跳转的：
# 1.  **第一步**：你输入 `vim`。
# 2.  **第二步**：系统在 `/usr/bin/vim` 找到入口。
# 3.  **第三步**：`/usr/bin/vim` 指向 `/etc/alternatives/vim`（备选方案软链接）。
# 4.  **第四步**（你刚查到的）：`/etc/alternatives/vim` 最终指向了 **`/usr/bin/vim.basic`**。
#-------------------------------------------------------------------------------------------------------------
fi

REMOTE_URL="https://Git.1-H.CC/Scripts/Linux/raw/branch/2026/devcontainer/apt-install-with-cache.sh"

if [[ $# -eq 0 ]]; then
  echo "❌ 错误: _apt-install-cached 未指定要安装的包。" >&2
  exit 1
fi

echo "📦 apt 安装: $*" >&2

# 桌面通知 (安装完成后自动关闭)
_NOTIFY_ID=""
if command -v notify-send > /dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    _NOTIFY_ID=$(notify-send --print-id -t 0 "📦 正在安装..." "$*" 2>/dev/null) || true
fi

# 创建临时 apt 配置，启用锁等待（-1 表示无限等待）
APT_WAIT_CONF=$(mktemp)
_cleanup() {
    rm -f "$APT_WAIT_CONF"
    if [ -n "${_NOTIFY_ID:-}" ]; then
        dbus-send --session --type=method_call \
            --dest=org.freedesktop.Notifications \
            /org/freedesktop/Notifications \
            org.freedesktop.Notifications.CloseNotification \
            "uint32:${_NOTIFY_ID}" 2>/dev/null || true
    fi
}
trap _cleanup EXIT
echo 'DPkg::Lock::Timeout "-1";' > "$APT_WAIT_CONF"
export APT_CONFIG="$APT_WAIT_CONF"

# -E 选项：保留（preserve）当前的环境变量
# 安装日志统一走 stderr，避免污染调用方 stdout（例如命令替换或重定向到配置文件）
# sudo -E _execute-remote-script "$REMOTE_URL" "$@" >&2

sudo APT_CONFIG="$APT_WAIT_CONF" _execute-remote-script "$REMOTE_URL" "$@" >&2

# 关闭"正在安装"通知，显示安装完成
if [ -n "$_NOTIFY_ID" ]; then
    notify-send --replace-id="$_NOTIFY_ID" -t 5000 "✅ 安装完成" "$*" 2>/dev/null || true
    _NOTIFY_ID=""
fi
