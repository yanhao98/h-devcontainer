#!/usr/bin/env bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail
#-------------------------------------------------------------------------------------------------------------
# desktop-lite: 本地化安装 VNC 桌面环境 (不再依赖远程脚本)
# https://github.com/devcontainers/features/blob/main/src/desktop-lite/install.sh
#-------------------------------------------------------------------------------------------------------------

# VNC 服务器 + 窗口管理器 (桌面启动最小依赖，仅 6 个包)
# 桌面应用和 X11 工具已有 bin-priority shim，首次使用时自动安装:
#   nautilus, mousepad, seahorse, xterm, tilix, htop, ncdu
#   xkill, editres, xfontsel, xrandr, xrefresh, xdg-open
# base image 已含: curl, ca-certificates, locales
#
# 以下非启动必需，不安装，但提升桌面可用性 (按需手动安装):
#   fbautostart         — fluxbox XDG 自动启动
#   at-spi2-core        — 无障碍框架，抑制 GTK 警告
#   gnome-keyring       — 凭据存储，VS Code 使用
#   xfonts-base xfonts-terminus — X11 字体
#   fonts-noto fonts-droid-fallback — 多语言字体
_apt-install-cached \
    tigervnc-standalone-server tigervnc-common tigervnc-tools \
    fluxbox dbus dbus-x11 \
    `# --- 以下非启动必需，但提升桌面可用性 ---` \
    fonts-wqy-microhei `# 中文字体 (~5MB)` \
    dunst libnotify-bin `# 桌面通知 (守护进程 + notify-send)` \
    gnome-icon-theme `# GTK 应用图标 (~15MB)` \
    fonts-noto-color-emoji `# 彩色 emoji 字体 (~10MB)`

# 创建必要目录
sudo mkdir -p /var/run/dbus /usr/local/etc/vscode-dev-containers/

# 设置 fluxbox 配置 (从 /devcontainer/fluxbox/ 拷贝默认配置)
mkdir -p ~/.fluxbox
touch ~/.Xmodmap
for f in apps init menu; do
    [ -e ~/.fluxbox/"$f" ] || cp /devcontainer/fluxbox/"$f" ~/.fluxbox/"$f"
done

# 确保 en_US.UTF-8 locale 存在
if ! grep -q -E '^\s*en_US.UTF-8\s+UTF-8' /etc/locale.gen 2>/dev/null; then
    echo "en_US.UTF-8 UTF-8" | sudo tee -a /etc/locale.gen >&2
    sudo locale-gen --keep-existing >&2
fi

# 安装 Cascadia Code 字体
# h-setup-cascadia-code-fonts >&2

# 设置 VNC 密码
VNC_PASSWORD="${PASSWORD:-vscode}"
if [ "${VNC_PASSWORD}" != "noPassword" ]; then
    echo "${VNC_PASSWORD}" | vncpasswd -f | sudo tee /usr/local/etc/vscode-dev-containers/vnc-passwd > /dev/null
fi

# 设置文件权限
sudo chmod +x /usr/local/share/desktop-init.sh /usr/local/bin/set-resolution

if [ "${DESKTOP_LITE_AUTOSTART:-1}" = "1" ]; then
    echo "🚀 正在后台启动 desktop-lite..." >&2
    nohup setsid /usr/local/share/desktop-init.sh >/dev/null 2>&1 &
    # postStartCommand 完成后，VS Code 会终止其所有子进程（包括后台启动的 VNC 服务器）。
    # - nohup: 忽略 SIGHUP 信号
    # - setsid: 创建新的 session，进程成为 session leader，完全脱离原终端/进程组
else
    echo "⏭️  跳过 desktop-lite 后台自启动，交由外部进程管理器接管。" >&2
fi
