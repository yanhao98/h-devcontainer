#!/bin/bash
# APT shim 辅助：检测包是否安装，未安装则自动安装，然后转发执行真实二进制
# 用法: exec _apt-shim-exec <package> <binary> "$@"
# 示例: exec _apt-shim-exec ffmpeg ffprobe "$@"

set -o errexit
set -o nounset
set -o pipefail

package="$1"; shift
binary="$1"; shift

if ! dpkg --status "$package" &>/dev/null; then
  _apt-install-cached "$package" >&2

  # 检查该包所有附带的二进制命令是否都有对应的 bin-priority shim
  missing=()
  while IFS= read -r bin_path; do
    bin_name="$(basename "$bin_path")"
    [ -f "/usr/local/bin-priority/$bin_name" ] || missing+=("$bin_name")
  done < <(dpkg -L "$package" 2>/dev/null | grep -E '^/usr/(s?bin|local/bin)/.+')

  if [ ${#missing[@]} -gt 0 ]; then
    echo "⚠️  包 $package 有以下命令未创建 bin-priority shim:" >&2
    printf '   - %s\n' "${missing[@]}" >&2
    echo "   📁 请在 .devcontainer/_build-context/rootfs/usr/local/bin-priority/ 中补充" >&2
  fi
fi

exec _exec-real-bin "$binary" "$@"
