#!/usr/bin/env bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

# 资料:
#   https://github.com/pnpm/get.pnpm.io/blob/main/install.sh
#   https://pnpm.io/installation#in-a-docker-container
#   https://github.dev/pnpm/pnpm/packages/plugin-commands-setup/src/setup.ts
#   https://pnpm.io/zh/settings#statedir
#   https://pnpm.io/zh/completion

cd ~

# 确定架构
arch="$(dpkg --print-architecture)"
case "${arch##*-}" in \
	amd64) build="x64";; \
	arm64) build="arm64";; \
	*) echo "❌ 错误: 不支持的架构: $arch" >&2; exit 1 ;; \
esac

base_asset_name="pnpm-linux-${build}"

# 统一的下载缓存目录
sudo mkdir -p /vscode/downloads || true
sudo chown -R $(whoami):$(whoami) /vscode/downloads || true

# 获取版本信息
if [[ -z "${PNPM_VERSION:-}" || "${PNPM_VERSION:-}" == "latest" ]]; then
    release_api_uri="https://api.github.com/repos/pnpm/pnpm/releases/latest"
else
    release_api_uri="https://api.github.com/repos/pnpm/pnpm/releases/tags/v${PNPM_VERSION}"
fi

echo "🔍 正在获取 pnpm 版本信息..." >&2
release_info=$(_curl-fsSL--compressed "$release_api_uri")
version=$(printf '%s\n' "$release_info" | jq -r ".tag_name // empty")
asset_name=$(printf '%s\n' "$release_info" | jq -r --arg name "$base_asset_name" '[.assets[] | select(.name == $name or .name == ($name + ".tar.gz"))][0].name // empty')
pnpm_uri=$(printf '%s\n' "$release_info" | jq -r --arg name "$asset_name" '.assets[] | select(.name == $name) | .browser_download_url // empty')
expected_checksum=$(printf '%s\n' "$release_info" | jq -r --arg name "$asset_name" '.assets[] | select(.name == $name) | (.digest // "") | sub("^sha256:"; "")')

if [[ -z "$version" || -z "$asset_name" || -z "$pnpm_uri" || -z "$expected_checksum" ]]; then
    echo "❌ 错误: 无法从 GitHub API 获取 pnpm 的发布信息。" >&2
    echo "API URI: $release_api_uri" >&2
    exit 1
fi

echo "📦 找到 pnpm ${version} (${asset_name})" >&2

# 缓存路径（包含版本号）
if [[ "$asset_name" == *.tar.gz ]]; then
    cached_pnpm_path="/vscode/downloads/${asset_name%.tar.gz}-${version}.tar.gz"
else
    cached_pnpm_path="/vscode/downloads/${asset_name}-${version}"
fi

# 检查是否存在且校验通过
need_download=true
if [[ -f "$cached_pnpm_path" ]]; then
    echo "📦 发现已存在的 pnpm 文件 ($cached_pnpm_path)，正在验证校验和..." >&2

    if _verify_checksum "$cached_pnpm_path" "$expected_checksum" >&2; then
        echo "✅ 校验和验证成功，跳过下载。" >&2
        need_download=false
    else
        echo "⚠️  校验和不匹配或验证失败，将重新下载。" >&2
    fi
fi

if [[ "$need_download" == "true" ]]; then
    echo "⬇️ 正在下载 pnpm ${version} (${asset_name})..." >&2
    _curl-fsSL--compressed -o "$cached_pnpm_path" "$pnpm_uri" || {
        echo "❌ 下载失败: $pnpm_uri" >&2; exit 1;
    }

    echo "🔐 正在验证下载的文件..." >&2
    if ! _verify_checksum "$cached_pnpm_path" "$expected_checksum" >&2; then
        echo "❌ 下载的文件校验失败" >&2; exit 1;
    fi
    echo "✅ 校验和验证成功。" >&2
fi

# 安装
echo "📥 正在安装 pnpm..." >&2

PNPM_HOME="${PNPM_HOME:-$HOME/.pnpm}"
tmp_dir="$(mktemp -d)" || { echo "❌ 创建临时目录失败" >&2; exit 1; }
trap "rm -rf '$tmp_dir'" EXIT INT TERM HUP

if [[ "$asset_name" == *.tar.gz ]]; then
    tar -xzf "$cached_pnpm_path" -C "$tmp_dir"
else
    cp "$cached_pnpm_path" "$tmp_dir/pnpm"
fi

if [[ ! -f "$tmp_dir/pnpm" ]]; then
    echo "❌ pnpm 归档文件中未找到 pnpm 可执行文件" >&2
    exit 1
fi

chmod +x "$tmp_dir/pnpm"

ENV="$HOME/.zshrc" SHELL="$(which zsh)" "$tmp_dir/pnpm" setup || { echo "❌ pnpm setup 失败" >&2; exit 1; }

# 配置 store 目录
cmd_pnpm="$PNPM_HOME/pnpm"
if [[ -x "$PNPM_HOME/bin/pnpm" ]]; then
    if [[ -L "$cmd_pnpm" ]]; then
        rm -f "$cmd_pnpm"
    fi

    cat > "$cmd_pnpm" <<'EOF'
#!/usr/bin/env sh
exec "$(dirname "$0")/bin/pnpm" "$@"
EOF
    chmod +x "$cmd_pnpm"
fi
if [[ ! -x "$cmd_pnpm" ]]; then
    echo "❌ pnpm setup 完成后未找到 pnpm 可执行文件" >&2
    exit 1
fi

$cmd_pnpm config set store-dir /vscode/pnpm/pnpm-store || { echo "❌ pnpm config set store-dir 失败" >&2; exit 1; }

# 安装 shell 补全
$cmd_pnpm completion zsh > ~/completion-for-pnpm.zsh
if ! grep -q 'source ~/completion-for-pnpm.zsh' ~/.zshrc; then
    echo 'source ~/completion-for-pnpm.zsh' >> ~/.zshrc
    echo "☑️  已添加 pnpm 自动补全到 ~/.zshrc" >&2
else
    echo "⏭️  pnpm 自动补全已存在于 ~/.zshrc 中" >&2
fi

# 验证安装
echo "✅ pnpm 安装成功：$($cmd_pnpm --version) ($PNPM_HOME/pnpm)" >&2
