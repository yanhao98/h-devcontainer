#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# route: 查看和管理路由表（传统工具，推荐用 ip route）
# 示例：
route -n                      # 显示路由表（数字格式）
route                         # 显示路由表（解析主机名）
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: route --version 2>&1 | head -1
exec _apt-shim-exec net-tools route "$@"
