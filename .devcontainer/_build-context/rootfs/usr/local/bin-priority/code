#!/bin/sh
# https://github.com/devcontainers/features/blob/main/src/common-utils/bin/code
# https://github.com/devcontainers/features/blob/b0188f0a5ef98f1c3217b6c0fe14c3ee472fad68/src/common-utils/main.sh#L599-L601
# code shim, it falls back to code-insiders or the code-server Remote CLI

code="$(_get-real-bin --silent code)"

if [ -n "$code" ]; then
    exec "$code" "$@"
fi

if [ "$(command -v code-insiders)" ]; then
    exec code-insiders "$@"
fi

if [ -n "${VSCODE_IPC_HOOK_CLI:-}" ]; then
    code_server_candidates="$(which -a code-server 2>/dev/null)"
    while IFS= read -r code_server_candidate; do
        case "$code_server_candidate" in
            */bin-priority/*) continue ;;
        esac

        code_server_cli="$(readlink -f "$code_server_candidate")"
        case "$code_server_cli" in
            */lib/vscode/bin/remote-cli/code-server)
                if [ -x "$code_server_cli" ]; then
                    exec "$code_server_cli" "$@"
                fi
                ;;
        esac
    done <<EOF
$code_server_candidates
EOF
fi

echo "code, code-insiders, or the code-server Remote CLI is not available" >&2
exit 127
