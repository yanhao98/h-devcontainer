#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# nc: 网络调试和数据传输工具（netcat）
# 示例：
nc -zv host 80                # 测试端口是否开放
nc -l 8080                    # 监听 8080 端口
nc host 8080 < file.txt       # 发送文件内容到远程主机
echo "test" | nc -w1 host 80  # 发送数据并设置超时
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: nc -h 2>&1 | head -1
exec _apt-shim-exec netcat-openbsd nc "$@"
