#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# ip: 网络接口和路由管理工具（iproute2）
# 示例：
ip addr                       # 查看所有网络接口地址
ip route                      # 查看路由表
ip link show                  # 查看网络接口状态
ip -br addr                   # 简洁格式显示地址
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: ip -V
exec _apt-shim-exec iproute2 ip "$@"
