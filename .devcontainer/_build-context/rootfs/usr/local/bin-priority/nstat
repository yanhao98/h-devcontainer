#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# nstat: 内核网络统计信息
# 示例：
nstat                            # 显示网络统计
nstat -a                          # 显示所有计数器
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: nstat -V 2>&1 | head -1
exec _apt-shim-exec iproute2 nstat "$@"
