#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# ss: 查看套接字统计信息（netstat 的现代替代）
# 示例：
ss -tlnp                      # 查看所有监听的 TCP 端口
ss -anp                       # 查看所有连接
ss -s                         # 显示套接字统计摘要
ss -tunlp                     # 查看所有 TCP/UDP 监听端口
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: ss --version
exec _apt-shim-exec iproute2 ss "$@"
