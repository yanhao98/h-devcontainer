#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# docker: 容器引擎 CLI（通过挂载的 docker.sock 连接主机 Docker）
# 示例：
docker ps                               # 列出运行中的容器
docker images                           # 列出本地镜像
docker run --rm alpine echo hello       # 运行一次性容器
docker compose up -d                    # 启动 compose 服务
docker buildx version                   # 查看 Buildx 版本
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: docker --version && docker buildx version

source /devcontainer/shim-utils.sh
_print_caller_info

_docker_buildx_plugin_installed() {
    local docker_config="${DOCKER_CONFIG:-${HOME:-}/.docker}"

    [ -n "$docker_config" ] && [ -x "$docker_config/cli-plugins/docker-buildx" ] && return 0
    [ -x /usr/local/lib/docker/cli-plugins/docker-buildx ] && return 0
    [ -x /usr/local/libexec/docker/cli-plugins/docker-buildx ] && return 0
    [ -x /usr/lib/docker/cli-plugins/docker-buildx ] && return 0
    [ -x /usr/libexec/docker/cli-plugins/docker-buildx ] && return 0

    return 1
}

_docker_socket_path() {
    local args=("$@")
    local docker_host="${DOCKER_HOST:-}"
    local i=0 arg

    while [ "$i" -lt "${#args[@]}" ]; do
        arg="${args[$i]}"
        case "$arg" in
            -H|--host)
                i=$((i + 1))
                docker_host="${args[$i]:-}"
                ;;
            -H*)
                docker_host="${arg#-H}"
                ;;
            --host=*)
                docker_host="${arg#--host=}"
                ;;
            --config|--context|-c|--log-level|--tlscacert|--tlscert|--tlskey)
                i=$((i + 1))
                ;;
            --config=*|--context=*|--log-level=*|--tlscacert=*|--tlscert=*|--tlskey=*|--tls|--tlsverify|--debug|-D|-c*)
                ;;
            -*)
                ;;
            *)
                break
                ;;
        esac

        i=$((i + 1))
    done

    if [ -z "$docker_host" ]; then
        echo "/var/run/docker.sock"
        return 0
    fi

    case "$docker_host" in
        unix://*) echo "${docker_host#unix://}" ;;
        *) return 1 ;;
    esac
}

_ensure_docker_socket_access() {
    local sock

    sock="$(_docker_socket_path "$@")" || return 0

    if [ -S "$sock" ] && { [ ! -r "$sock" ] || [ ! -w "$sock" ]; }; then
        echo "⚠️  当前用户 $(id -un) 无权访问 Docker socket: $sock" >&2
        echo "   请使用 sudo docker $* 重新执行。" >&2
        exit 1
    fi
}

docker_bin="$(_get-real-bin --silent docker)"

if [ -z "$docker_bin" ]; then
    echo "⚠️  docker CLI 未安装，正在自动安装..." >&2
    h-setup-docker-bin >&2
fi

if [ "${1:-}" = "buildx" ] && ! _docker_buildx_plugin_installed; then
    echo "⚠️  docker buildx 未安装，正在自动安装..." >&2
    h-setup-docker-bin >&2
fi

_ensure_docker_socket_access "$@"

exec _exec-real-bin docker "$@"
