#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# docker: 容器引擎 CLI（通过挂载的 docker.sock 连接主机 Docker）
# 示例：
docker ps                               # 列出运行中的容器
docker images                           # 列出本地镜像
docker run --rm alpine echo hello       # 运行一次性容器
docker compose up -d                    # 启动 compose 服务
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: docker --version

source /devcontainer/shim-utils.sh
_print_caller_info

docker_bin="$(_get-real-bin --silent docker)"

if [ -z "$docker_bin" ]; then
    echo "⚠️  docker CLI 未安装，正在自动安装..." >&2
    h-setup-docker-bin >&2
fi

exec _exec-real-bin docker "$@"
