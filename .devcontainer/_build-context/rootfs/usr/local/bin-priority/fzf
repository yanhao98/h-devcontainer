#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# fzf: 通用命令行模糊搜索工具
# 示例：
fzf                           # 交互式模糊搜索当前目录文件
cat list.txt | fzf            # 从列表中模糊选择一行
git branch | fzf              # 模糊搜索 git 分支
# zsh 快捷键（需 oh-my-zsh fzf 插件）：
# Ctrl+R  模糊搜索历史命令
# Ctrl+T  模糊查找文件并插入路径
# Alt+C   模糊查找子目录并 cd 进入
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: fzf --version
exec _apt-shim-exec fzf fzf "$@"
