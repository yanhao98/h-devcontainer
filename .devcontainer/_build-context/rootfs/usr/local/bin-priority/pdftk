#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

if false; then
#-------------------------------------------------------------------------------
# pdftk: PDF 工具箱（合并、拆分、旋转等）
# 示例：
pdftk a.pdf b.pdf cat output merged.pdf       # 合并 PDF
pdftk input.pdf burst                         # 拆分成单页
pdftk input.pdf rotate 1east output out.pdf   # 旋转第一页
#-------------------------------------------------------------------------------
fi

# @verify: pdftk --version 2>&1 | head -1
exec _apt-shim-exec pdftk-java pdftk "$@"
