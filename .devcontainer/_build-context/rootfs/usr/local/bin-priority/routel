#!/bin/bash
set -o errexit    # 对应 -e
set -o nounset    # 对应 -u
set -o pipefail   # 对应 -o pipefail

if false; then
#-------------------------------------------------------------------------------------------------------------
# routel: 以表格形式显示路由
# 示例：
routel                           # 以表格形式显示路由表
#-------------------------------------------------------------------------------------------------------------
fi

# @verify: routel 2>&1 | head -1
exec _apt-shim-exec iproute2 routel "$@"
