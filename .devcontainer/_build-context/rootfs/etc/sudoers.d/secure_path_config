# Dev container 中 usr_vscode 已配置 NOPASSWD sudo。
# ENTRYPOINT 默认以 usr_vscode 启动，然后通过 `sudo "$0" "$@"` 重进自身为 root 来启动 supervisord。
# 因此 sudo 需要尽量保留调用方环境，否则 BASH_ENV、完整 PATH 和未来新增的普通环境变量会在重进 root 时丢失。

# 关闭 sudo 默认的环境重置；否则 sudo 只保留少量安全变量。
Defaults !env_reset

# 关闭 sudo 的固定 secure_path；否则 sudo 会用自己的 PATH 覆盖 devcontainer 当前 PATH。
Defaults !secure_path

# BASH_ENV/ENV 默认在 sudo 的删除列表中；移除后，非交互式 bash 的初始化入口能通过 sudo 传递。
Defaults env_delete -= "BASH_ENV ENV"

# 注意：LD_PRELOAD 这类变量可能在 setuid sudo 启动前已被动态链接器剥离，sudoers 无法原生保留。
